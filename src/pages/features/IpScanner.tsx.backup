
import React, { useState } from 'react';
import { Card } from '../../components/Card';
import { Input } from '../../components/Input';
import { Button } from '../../components/Button';
import { api } from '../../services/api';
import { 
    Search, Globe, Shield, ShieldAlert, ShieldCheck, ShieldX,
    AlertTriangle, Server, Network, MapPin, Building2, 
    Radio, Eye, EyeOff, Wifi, WifiOff, Lock, Unlock,
    Activity, CheckCircle2, XCircle, AlertCircle,
    Zap, Globe2, Clock, Hash, Download, FileSpreadsheet, FileText
} from 'lucide-react';

interface ThreatIntelligence {
    is_vpn: boolean;
    is_proxy: boolean;
    is_tor_exit: boolean;
    is_datacenter: boolean;
    is_bot: boolean;
    abuse_reports: number;
    abuse_confidence_score: number;
    fraud_score: number;
    is_blacklisted: boolean;
    threat_categories: string[];
    last_reported: string | null;
    usage_type: string;
    isp_name: string;
    connection_type: string;
    is_mobile: boolean;
}

interface NetworkInfo {
    asn: string;
    asn_name: string;
    network_range: string;
    organization: string;
    isp: string;
    domain: string;
}

interface GeographicDetails {
    country: string;
    country_code: string;
    region: string;
    region_name: string;
    city: string;
    zip_code: string;
    latitude: number;
    longitude: number;
    timezone: string;
    continent: string;
}

interface AbuseHistory {
    total_reports: number;
    distinct_users: number;
    last_reported_at: string | null;
    report_categories: string[];
    abuse_confidence: number;
    is_whitelisted: boolean;
}

interface PortScan {
    open_ports: number[];
    services_detected: { [key: number]: string };
}

interface DNSInfo {
    reverse_dns: string;
    ptr_records: string[];
}

interface RiskFactor {
    name: string;
    impact: number;
    description: string;
}

interface RiskAssessment {
    score: number;
    severity: string;
    factors: RiskFactor[];
    recommendation: string;
    is_malicious: boolean;
}

interface ScanResult {
    ip: string;
    geolocation: any;
    network_info: NetworkInfo;
    geographic_details: GeographicDetails;
    threat_intelligence: ThreatIntelligence;
    abuse_history: AbuseHistory;
    port_scan: PortScan;
    dns_info: DNSInfo;
    risk_assessment: RiskAssessment;
    scan_timestamp: string;
}

const getSeverityColor = (severity: string) => {
    switch (severity.toLowerCase()) {
        case 'low': return { text: 'text-emerald-400', bg: 'bg-emerald-500', gradient: 'from-emerald-500 to-green-600' };
        case 'medium': return { text: 'text-amber-400', bg: 'bg-amber-500', gradient: 'from-amber-500 to-yellow-600' };
        case 'high': return { text: 'text-orange-400', bg: 'bg-orange-500', gradient: 'from-orange-500 to-red-600' };
        case 'critical': return { text: 'text-red-500', bg: 'bg-red-500', gradient: 'from-red-500 to-rose-700' };
        default: return { text: 'text-gray-400', bg: 'bg-gray-500', gradient: 'from-gray-500 to-gray-600' };
    }
};

const getScoreColor = (score: number): string => {
    if (score <= 25) return '#10b981';
    if (score <= 50) return '#f59e0b';
    if (score <= 75) return '#f97316';
    return '#ef4444';
};

const RiskGauge = ({ score, severity }: { score: number; severity: string }) => {
    const circumference = 2 * Math.PI * 54;
    const progress = (score / 100) * circumference;
    const color = getScoreColor(score);
    const colors = getSeverityColor(severity);

    return (
        <div className="relative flex flex-col items-center justify-center">
            {/* Glow effect */}
            <div 
                className="absolute w-40 h-40 rounded-full blur-xl opacity-30"
                style={{ backgroundColor: color }}
            />
            
            <svg className="w-44 h-44 transform -rotate-90" viewBox="0 0 120 120">
                {/* Background circle */}
                <circle
                    cx="60" cy="60" r="54"
                    stroke="rgba(255,255,255,0.1)"
                    strokeWidth="10"
                    fill="none"
                />
                {/* Progress circle */}
                <circle
                    cx="60" cy="60" r="54"
                    stroke={color}
                    strokeWidth="10"
                    fill="none"
                    strokeDasharray={circumference}
                    strokeDashoffset={circumference - progress}
                    strokeLinecap="round"
                    className="transition-all duration-1000 ease-out"
                    style={{ filter: `drop-shadow(0 0 8px ${color})` }}
                />
            </svg>
            
            {/* Center content */}
            <div className="absolute flex flex-col items-center justify-center">
                <span 
                    className="text-5xl font-bold tracking-tight"
                    style={{ color, textShadow: `0 0 20px ${color}40` }}
                >
                    {score}
                </span>
                <span className={`text-lg font-semibold mt-1 ${colors.text}`}>
                    {severity} Risk
                </span>
            </div>
        </div>
    );
};

const ThreatBadge = ({ active, label, icon: Icon }: { active: boolean; label: string; icon: any }) => (
    <div className={`
        relative overflow-hidden rounded-xl p-4 transition-all duration-300
        ${active 
            ? 'bg-gradient-to-br from-red-500/20 to-red-900/20 border border-red-500/40 shadow-lg shadow-red-500/10' 
            : 'bg-gradient-to-br from-emerald-500/10 to-emerald-900/10 border border-emerald-500/30'
        }
    `}>
        {/* Gradient overlay */}
        <div className={`absolute inset-0 opacity-20 ${active ? 'bg-gradient-to-r from-red-500 to-transparent' : 'bg-gradient-to-r from-emerald-500 to-transparent'}`} />
        
        <div className="relative flex items-center justify-between">
            <div className="flex items-center gap-3">
                <div className={`p-2 rounded-lg ${active ? 'bg-red-500/20' : 'bg-emerald-500/20'}`}>
                    <Icon size={20} className={active ? 'text-red-400' : 'text-emerald-400'} />
                </div>
                <span className="font-semibold text-white">{label}</span>
            </div>
            <div className={`flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide
                ${active 
                    ? 'bg-red-500/30 text-red-300' 
                    : 'bg-emerald-500/30 text-emerald-300'
                }`}>
                {active ? <XCircle size={14} /> : <CheckCircle2 size={14} />}
                {active ? 'Detected' : 'Clear'}
            </div>
        </div>
    </div>
);

const InfoRow = ({ label, value, icon: Icon }: { label: string; value: string; icon?: any }) => (
    <div className="flex items-center justify-between py-3 border-b border-white/5 last:border-0">
        <div className="flex items-center gap-2 text-gray-400">
            {Icon && <Icon size={16} />}
            <span>{label}</span>
        </div>
        <span className="font-medium text-white">{value || 'N/A'}</span>
    </div>
);

export const IpScanner = () => {
    const [ip, setIp] = useState('');
    const [loading, setLoading] = useState(false);
    const [result, setResult] = useState<ScanResult | null>(null);
    const [error, setError] = useState<string | null>(null);
    const [exportingExcel, setExportingExcel] = useState(false);
    const [exportingPdf, setExportingPdf] = useState(false);

    const handleScan = async (e: React.FormEvent) => {
        e.preventDefault();
        setLoading(true);
        setError(null);
        setResult(null);

        try {
            const response = await api.post(`/ip/scan?ip_address=${encodeURIComponent(ip)}`);
            setResult(response.data);
        } catch (err: any) {
            setError(err.response?.data?.detail || err.message || "Scan failed");
        } finally {
            setLoading(false);
        }
    };

    const handleExportExcel = async () => {
        if (!result) return;
        setExportingExcel(true);
        try {
            const response = await api.post(`/ip/scan/export/excel?ip_address=${encodeURIComponent(ip)}`, {}, {
                responseType: 'blob'
            });
            const url = window.URL.createObjectURL(new Blob([response.data]));
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', `ip_scan_${ip}_${new Date().toISOString().split('T')[0]}.xlsx`);
            document.body.appendChild(link);
            link.click();
            link.remove();
        } catch (err: any) {
            setError("Export failed: " + (err.response?.data?.detail || err.message));
        } finally {
            setExportingExcel(false);
        }
    };

    const handleExportPdf = async () => {
        if (!result) return;
        setExportingPdf(true);
        try {
            const response = await api.post(`/ip/scan/export/pdf?ip_address=${encodeURIComponent(ip)}`, {}, {
                responseType: 'blob'
            });
            const url = window.URL.createObjectURL(new Blob([response.data]));
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', `ip_scan_${ip}_${new Date().toISOString().split('T')[0]}.pdf`);
            document.body.appendChild(link);
            link.click();
            link.remove();
        } catch (err: any) {
            setError("Export failed: " + (err.response?.data?.detail || err.message));
        } finally {
            setExportingPdf(false);
        }
    };

    const colors = result ? getSeverityColor(result.risk_assessment.severity) : null;

    return (
        <div className="flex flex-col gap-8 max-w-6xl mx-auto pb-8">
            {/* Header */}
            <div className="flex items-center gap-5">
                <div className="relative">
                    <div className="absolute inset-0 bg-cyan-500 blur-xl opacity-30 rounded-full" />
                    <div className="relative p-4 bg-gradient-to-br from-cyan-500/20 to-blue-600/20 rounded-2xl border border-cyan-500/30">
                        <Globe size={36} className="text-cyan-400" />
                    </div>
                </div>
                <div>
                    <h1 className="text-4xl font-bold bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
                        IP Scanner
                    </h1>
                    <p className="text-gray-400 mt-1">Advanced threat intelligence & risk analysis</p>
                </div>
            </div>

            {/* Search Form */}
                <Card>
                    <form onSubmit={handleScan} className="flex gap-4 items-end">
                        <Input 
                            label="Target IP Address" 
                            placeholder="Enter IP address (e.g., 8.8.8.8)" 
                            value={ip}
                            onChange={(e) => setIp(e.target.value)}
                            icon={<Search size={18} />}
                            required
                        />
                        <Button 
                            type="submit" 
                            isLoading={loading} 
                            variant="primary"
                            className="px-8 py-3 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 shadow-lg shadow-cyan-500/25"
                        >
                            {loading ? (
                                'Analyzing...'
                            ) : (
                                <span className="flex items-center gap-2">
                                    <Zap size={18} />
                                    Deep Scan
                                </span>
                            )}
                        </Button>
                    </form>
                </Card>


            {/* Error Display */}
            {error && (
                <div className="p-5 bg-gradient-to-r from-red-500/10 to-red-900/10 border border-red-500/40 rounded-xl flex items-center gap-4">
                    <div className="p-3 bg-red-500/20 rounded-lg">
                        <AlertTriangle size={24} className="text-red-400" />
                    </div>
                    <div>
                        <h4 className="font-semibold text-red-400">Scan Failed</h4>
                        <p className="text-gray-400 text-sm">{error}</p>
                    </div>
                </div>
            )}

            {/* Export Buttons */}
            {result && (
                <div className="flex gap-4 justify-end">
                    <Button
                        onClick={handleExportExcel}
                        isLoading={exportingExcel}
                        variant="outline"
                        className="px-6 py-2 border-emerald-500/50 hover:bg-emerald-500/10"
                    >
                        <span className="flex items-center gap-2">
                            <FileSpreadsheet size={18} className="text-emerald-400" />
                            Export to Excel
                        </span>
                    </Button>
                    <Button
                        onClick={handleExportPdf}
                        isLoading={exportingPdf}
                        variant="outline"
                        className="px-6 py-2 border-red-500/50 hover:bg-red-500/10"
                    >
                        <span className="flex items-center gap-2">
                            <FileText size={18} className="text-red-400" />
                            Export to PDF
                        </span>
                    </Button>
                </div>
            )}

            {/* Results */}
            {result && (
                <div className="space-y-6 animate-fade-in">
                    
                    {/* Risk Assessment - Hero Card */}
                    <div className={`relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-gray-900/80 to-gray-950/80 backdrop-blur-xl`}>
                        {/* Background gradient based on severity */}
                        <div className={`absolute top-0 right-0 w-96 h-96 bg-gradient-to-br ${colors?.gradient} opacity-10 blur-3xl`} />
                        
                        <div className="relative p-8">
                            <h3 className="text-xl font-bold text-white mb-8 flex items-center gap-3">
                                <Shield className={colors?.text} size={24} />
                                Risk Assessment
                            </h3>
                            
                            <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
                                {/* Risk Gauge */}
                                <div className="flex items-center justify-center">
                                    <RiskGauge 
                                        score={result.risk_assessment.score} 
                                        severity={result.risk_assessment.severity} 
                                    />
                                </div>
                                
                                {/* Risk Factors */}
                                <div className="lg:col-span-2 space-y-4">
                                    <h4 className="text-sm font-semibold text-gray-400 uppercase tracking-wider flex items-center gap-2">
                                        <AlertCircle size={16} />
                                        Risk Factors
                                    </h4>
                                    
                                    {result.risk_assessment.factors.length > 0 ? (
                                        <div className="space-y-3">
                                            {result.risk_assessment.factors.map((factor, idx) => (
                                                <div 
                                                    key={idx} 
                                                    className="flex items-start gap-4 p-4 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 transition-colors"
                                                >
                                                    <div className="flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-red-500/20 to-orange-500/20 flex items-center justify-center">
                                                        <span className="text-lg font-bold text-red-400">+{factor.impact}</span>
                                                    </div>
                                                    <div className="flex-1 min-w-0">
                                                        <div className="font-semibold text-white">{factor.name}</div>
                                                        <div className="text-sm text-gray-400 mt-0.5">{factor.description}</div>
                                                    </div>
                                                </div>
                                            ))}
                                        </div>
                                    ) : (
                                        <div className="flex items-center gap-3 p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/30">
                                            <ShieldCheck size={24} className="text-emerald-400" />
                                            <span className="text-emerald-300 font-medium">No risk factors detected — This IP appears safe</span>
                                        </div>
                                    )}
                                    
                                    {/* Recommendation */}
                                    <div className={`mt-6 p-4 rounded-xl bg-gradient-to-r ${colors?.gradient} bg-opacity-10 border border-white/10`}>
                                        <div className="flex items-start gap-3">
                                            <Shield size={20} className="text-white mt-0.5 flex-shrink-0" />
                                            <div>
                                                <span className="font-semibold text-white">Recommendation</span>
                                                <p className="text-white/80 text-sm mt-1">{result.risk_assessment.recommendation}</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {/* Malicious IP Indicators */}
                    {(result.threat_intelligence.abuse_confidence_score > 0 || result.threat_intelligence.fraud_score > 0) && (
                        <div className="rounded-2xl border border-white/10 bg-gradient-to-br from-gray-900/80 to-gray-950/80 backdrop-blur-xl p-6">
                            <h3 className="text-lg font-bold text-white mb-5 flex items-center gap-3">
                                <AlertTriangle className="text-orange-400" size={22} />
                                Malicious IP Indicators
                            </h3>
                            
                            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                                {/* Abuse Confidence Score */}
                                <div className="p-4 rounded-xl bg-gradient-to-br from-red-500/10 to-orange-500/10 border border-red-500/30">
                                    <div className="text-sm text-gray-400 mb-2">Abuse Confidence</div>
                                    <div className="flex items-end gap-2">
                                        <span className="text-3xl font-bold text-red-400">{result.threat_intelligence.abuse_confidence_score}%</span>
                                    </div>
                                    <div className="mt-2 h-2 bg-gray-700 rounded-full overflow-hidden">
                                        <div 
                                            className="h-full bg-gradient-to-r from-red-500 to-orange-500"
                                            style={{ width: `${result.threat_intelligence.abuse_confidence_score}%` }}
                                        />
                                    </div>
                                    <div className="text-xs text-gray-500 mt-2">
                                        {result.threat_intelligence.abuse_reports} reports
                                    </div>
                                </div>

                                {/* Fraud Score */}
                                <div className="p-4 rounded-xl bg-gradient-to-br from-orange-500/10 to-yellow-500/10 border border-orange-500/30">
                                    <div className="text-sm text-gray-400 mb-2">Fraud Score</div>
                                    <div className="flex items-end gap-2">
                                        <span className="text-3xl font-bold text-orange-400">{result.threat_intelligence.fraud_score}%</span>
                                    </div>
                                    <div className="mt-2 h-2 bg-gray-700 rounded-full overflow-hidden">
                                        <div 
                                            className="h-full bg-gradient-to-r from-orange-500 to-yellow-500"
                                            style={{ width: `${result.threat_intelligence.fraud_score}%` }}
                                        />
                                    </div>
                                    <div className="text-xs text-gray-500 mt-2">
                                        Likelihood of fraudulent activity
                                    </div>
                                </div>

                                {/* Blacklist Status */}
                                <div className={`p-4 rounded-xl border ${
                                    result.threat_intelligence.is_blacklisted
                                        ? 'bg-gradient-to-br from-red-500/20 to-red-900/20 border-red-500/40'
                                        : 'bg-gradient-to-br from-emerald-500/10 to-emerald-900/10 border-emerald-500/30'
                                }`}>
                                    <div className="text-sm text-gray-400 mb-2">Blacklist Status</div>
                                    <div className="flex items-center gap-3 mt-3">
                                        {result.threat_intelligence.is_blacklisted ? (
                                            <>
                                                <ShieldX size={32} className="text-red-400" />
                                                <span className="text-xl font-bold text-red-400">BLACKLISTED</span>
                                            </>
                                        ) : (
                                            <>
                                                <ShieldCheck size={32} className="text-emerald-400" />
                                                <span className="text-xl font-bold text-emerald-400">CLEAN</span>
                                            </>
                                        )}
                                    </div>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* Threat Intelligence */}
                    <div className="rounded-2xl border border-white/10 bg-gradient-to-br from-gray-900/80 to-gray-950/80 backdrop-blur-xl p-6">
                        <h3 className="text-lg font-bold text-white mb-5 flex items-center gap-3">
                            <ShieldAlert className="text-purple-400" size={22} />
                            Threat Intelligence
                        </h3>
                        
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <ThreatBadge 
                                active={result.threat_intelligence.is_vpn} 
                                label="VPN Service" 
                                icon={result.threat_intelligence.is_vpn ? EyeOff : Eye} 
                            />
                            <ThreatBadge 
                                active={result.threat_intelligence.is_proxy} 
                                label="Proxy Server" 
                                icon={Network} 
                            />
                            <ThreatBadge 
                                active={result.threat_intelligence.is_tor_exit} 
                                label="Tor Exit Node" 
                                icon={result.threat_intelligence.is_tor_exit ? Unlock : Lock} 
                            />
                            <ThreatBadge 
                                active={result.threat_intelligence.is_blacklisted} 
                                label="Blacklisted" 
                                icon={result.threat_intelligence.is_blacklisted ? ShieldX : ShieldCheck} 
                            />
                        </div>
                        
                        {result.threat_intelligence.threat_categories.length > 0 && (
                            <div className="mt-5 pt-5 border-t border-white/10">
                                <div className="text-sm text-gray-400 mb-3">Active Threat Categories</div>
                                <div className="flex flex-wrap gap-2">
                                    {result.threat_intelligence.threat_categories.map((cat, idx) => (
                                        <span 
                                            key={idx} 
                                            className="px-4 py-2 bg-gradient-to-r from-orange-500/20 to-red-500/20 text-orange-300 rounded-full text-sm font-medium border border-orange-500/30"
                                        >
                                            {cat}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>

                    {/* Geolocation & DNS Grid */}
                    <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        {/* Geolocation Card */}
                        <div className="rounded-2xl border border-white/10 bg-gradient-to-br from-gray-900/80 to-gray-950/80 backdrop-blur-xl p-6">
                            <h3 className="text-lg font-bold text-white mb-5 flex items-center gap-3">
                                <MapPin className="text-cyan-400" size={22} />
                                Geolocation
                            </h3>
                            
                            {/* IP Address highlight */}
                            <div className="mb-5 p-4 rounded-xl bg-gradient-to-r from-cyan-500/10 to-blue-500/10 border border-cyan-500/20">
                                <div className="text-sm text-gray-400 mb-1">IP Address</div>
                                <div className="text-2xl font-mono font-bold text-cyan-400">{result.ip}</div>
                            </div>
                            
                            <div className="space-y-1">
                                <InfoRow label="Country" value={result.geolocation.country} icon={Globe2} />
                                <InfoRow label="City" value={result.geolocation.city} icon={MapPin} />
                                <InfoRow label="Region" value={result.geolocation.regionName} />
                                <InfoRow label="Timezone" value={result.geolocation.timezone} icon={Clock} />
                                <InfoRow label="ISP" value={result.geolocation.isp} icon={Building2} />
                                <InfoRow label="Organization" value={result.geolocation.org} />
                            </div>
                        </div>

                        {/* DNS Info Card */}
                        <div className="rounded-2xl border border-white/10 bg-gradient-to-br from-gray-900/80 to-gray-950/80 backdrop-blur-xl p-6">
                            <h3 className="text-lg font-bold text-white mb-5 flex items-center gap-3">
                                <Server className="text-violet-400" size={22} />
                                DNS Information
                            </h3>
                            
                            <div className="p-4 rounded-xl bg-violet-500/10 border border-violet-500/20 mb-5">
                                <div className="text-sm text-gray-400 mb-2">Reverse DNS (PTR)</div>
                                <div className="font-mono text-violet-300 break-all">
                                    {result.dns_info.reverse_dns || 'No PTR record'}
                                </div>
                            </div>
                            
                            {result.dns_info.ptr_records && result.dns_info.ptr_records.length > 1 && (
                                <div className="space-y-2">
                                    <div className="text-sm text-gray-400">Additional Records</div>
                                    {result.dns_info.ptr_records.slice(1).map((ptr, idx) => (
                                        <div key={idx} className="font-mono text-sm text-gray-400 p-2 rounded bg-white/5">
                                            {ptr}
                                        </div>
                                    ))}
                                </div>
                            )}
                            
                            {/* Port Scan Results in same card for better layout */}
                            <div className="mt-6 pt-6 border-t border-white/10">
                                <h4 className="text-md font-semibold text-white mb-4 flex items-center gap-2">
                                    <Radio className="text-emerald-400" size={18} />
                                    Open Ports
                                </h4>
                                
                                {result.port_scan.open_ports.length > 0 ? (
                                    <div className="flex flex-wrap gap-2">
                                        {result.port_scan.open_ports.map((port) => (
                                            <div 
                                                key={port} 
                                                className={`px-4 py-2 rounded-lg border ${
                                                    [22, 23, 3389, 445].includes(port)
                                                        ? 'bg-orange-500/10 border-orange-500/40 text-orange-300'
                                                        : 'bg-emerald-500/10 border-emerald-500/30 text-emerald-300'
                                                }`}
                                            >
                                                <span className="font-mono font-bold">{port}</span>
                                                <span className="text-xs ml-2 opacity-70">
                                                    {result.port_scan.services_detected[port]}
                                                </span>
                                            </div>
                                        ))}
                                    </div>
                                ) : (
                                    <div className="flex items-center gap-2 text-gray-400 text-sm">
                                        <WifiOff size={16} />
                                        No open ports detected
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
};
